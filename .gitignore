# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Playwright E2E
/test-results
/playwright-report
/blob-report

# Playwright skill (the playwright-cli wrapper used for local UI debugging):
# its per-session console logs, plus the screenshots it writes under output/.
# Local-only debugging artifacts, never committed.
/.playwright-cli/
/output/

# Claude Code agent working dirs — local scratch space + the isolated git
# worktrees it creates for parallel agents. Ephemeral, never committed.
# (.claude/.DS_Store is already covered by the .DS_Store rule further down.)
/.claude/scratch/
/.claude/worktrees/

# VitePress docs site (built by .github/workflows/docs.yml, not committed)
docs/.vitepress/dist
docs/.vitepress/cache

# `pnpm flamegraph` (scripts/profile.mjs) — samply's own recording output,
# written to the repo root (samply's default -o path is relative to the
# cwd it's invoked from). Local profiling artifacts, never meant to be
# committed.
profile.json.gz
profile.kernel.etl

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
